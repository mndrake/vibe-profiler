{#- automate-dv link model template -#}
{{ '{{' }} config(materialized='{{ materialized }}', schema='{{ schema }}') {{ '}}' }}

{%- set src_pk_str -%}"{{ hash_key }}"{%- endset %}
{%- set src_fk_list -%}
[
{%- for fk in foreign_keys -%}
"{{ fk }}"{{ ", " if not loop.last }}
{%- endfor -%}
]
{%- endset %}
{%- set src_ldts_str -%}"{{ load_date_column }}"{%- endset %}
{%- set src_source_str -%}"{{ record_source_column }}"{%- endset %}
{%- set source_model_str -%}"{{ staging_model }}"{%- endset %}

{{ '{%' }} set src_pk = {{ src_pk_str }} {{ '%}' }}
{{ '{%' }} set src_fk = {{ src_fk_list }} {{ '%}' }}
{{ '{%' }} set src_ldts = {{ src_ldts_str }} {{ '%}' }}
{{ '{%' }} set src_source = {{ src_source_str }} {{ '%}' }}
{{ '{%' }} set source_model = {{ source_model_str }} {{ '%}' }}

{{ '{{' }} automate_dv.link(src_pk=src_pk,
               src_fk=src_fk,
               src_ldts=src_ldts,
               src_source=src_source,
               source_model=source_model) {{ '}}' }}
